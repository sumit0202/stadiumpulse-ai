# =========================================================================
# StadiumPulse AI - Environment configuration (EXAMPLE / SAFE TO COMMIT)
# Copy to `.env` and fill values to enable LIVE mode. Without keys the app
# runs fully in DEMO mode using typed mock adapters.
# NEVER commit a real .env file. Secrets belong to the backend only.
# =========================================================================

# ---- Backend (server-only secrets, never exposed to the browser) ----
# Gemini / Google Generative AI. Backend proxy only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Server-side key used by adapters that the proxy calls (Translation, Routes,
# Places, Geocoding, Time Zone, Air Quality). Kept on the server.
GOOGLE_SERVER_API_KEY=

# Backend listen port and allowed CORS origin for local development.
PORT=8787
CORS_ORIGIN=http://localhost:5173

# Assistant endpoint rate limit (requests per window / window in ms).
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# ---- Frontend (safe, browser-exposed) ----
# Google Maps JavaScript API browser key. Restrict by HTTP referrer.
# This is the ONLY Google key that is allowed in the client.
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Base URL for the backend proxy as seen by the browser.
VITE_API_BASE_URL=/api
